# WhatsApp de destino en formato internacional
NEXT_PUBLIC_WHATSAPP_NUMBER=573136486022

# (Opcional) Para habilitar el chat de texto con OpenAI
OPENAI_API_KEY=

# (Opcional) Imágenes: primero Hugging Face; si falta crédito prepago (fal-ai) o el modelo falla, se usa Pollinations gratis.
# Token hf_... con permisos: lectura del Hub + "Make calls to Inference Providers"
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
# Modelo y proveedor (por defecto: stabilityai/stable-diffusion-2 + hf-inference, sin prepago)
# Con créditos en fal-ai puedes poner: HUGGINGFACE_IMAGE_PROVIDER=fal-ai y p.ej. FLUX.1-schnell
# HUGGINGFACE_IMAGE_MODEL=
# HUGGINGFACE_IMAGE_PROVIDER=
# Tiempo máx. esperando a HF (ms); al vencer → Pollinations. Por defecto 35000
# HUGGINGFACE_IMAGE_TIMEOUT_MS=
# Solo Pollinations (el servidor descarga la imagen y la envía al navegador): HUGGINGFACE_IMAGE_ONLY_POLLINATIONS=1
# Tiempo máx. esperando a Pollinations al generar la imagen (ms). Por defecto 120000
# POLLINATIONS_FETCH_TIMEOUT_MS=
